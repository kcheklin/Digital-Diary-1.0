<AnchorPane id="AnchorPane" prefHeight="497.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.system.fop.WelcomeController">
    <children>
      <ImageView fitHeight="497.0" fitWidth="600.0" pickOnBounds="true">
