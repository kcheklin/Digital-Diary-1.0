<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.system.fop.TrackMoodController">
   <children>
      <ImageView fitHeight="400.0" fitWidth="600.0" opacity="0.5" pickOnBounds="true">
         <image>
            <Image url="@IMG_202501069840_600x497.jpg" />
         </image>
      </ImageView>
      <Text layoutX="226.0" layoutY="93.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Time Range">
         <font>
            <Font name="Times New Roman" size="30.0" />
         </font>
      </Text>
      <DatePicker fx:id="startDatePicker" layoutX="276.0" layoutY="154.0" promptText="Select start date" />
      <DatePicker fx:id="endDatePicker" layoutX="276.0" layoutY="236.0" promptText="Select end date" />
      <Text layoutX="185.0" layoutY="172.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Start Date:">
         <font>
            <Font name="Times New Roman" size="17.0" />
         </font>
      </Text>
      <Text layoutX="187.0" layoutY="254.0" strokeType="OUTSIDE" strokeWidth="0.0" text="End Date:">
         <font>
            <Font name="Times New Roman" size="17.0" />
         </font>
      </Text>
      <Button fx:id="confirmButton" layoutX="259.0" layoutY="315.0" mnemonicParsing="false" onAction="#onConfirmButtonClick" style="-fx-background-color: rgba(39,24,24,0.65);" text="Confirm" textFill="WHITE">
         <font>
            <Font name="Times New Roman" size="15.0" />
         </font></Button>
   </children>
</AnchorPane>
